# Value Maps runs with NO configuration (community is in demo mode).
#
# To persist & SHARE community responses, add ONE datastore below and redeploy.
# Copy this file to .env.local for local development.

# ── Option A: Supabase (recommended, free tier) ──────────────────────────────
# 1. SQL Editor → run the contents of supabase/schema.sql (creates one table)
# 2. Project Settings → API → copy the service_role key below
#    (SECRET — server-side only, never expose as NEXT_PUBLIC_*)
# The URL already defaults to this project in code, so the key is all you need.
SUPABASE_URL=https://frlfegdrniztuoijlpny.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Option B: Upstash Redis / Vercel KV (alternative) ────────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# (KV_REST_API_URL / KV_REST_API_TOKEN also work)

# ── Optional: canonical site URL for absolute share-image links ──────────────
# Set this to your custom domain (otherwise the Vercel production URL is used).
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
