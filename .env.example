# Value Maps runs with NO configuration (demo mode).
#
# To persist and SHARE real responses across visitors, provide a serverless
# Redis. Both Upstash and Vercel KV style names are supported — set ONE pair.
# Copy this file to .env.local for local development.

# Upstash Redis (Vercel Marketplace → Upstash, or upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ...or Vercel KV style names (either pair works)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
